------bubble sort ---------
#include<stdio.h>
int main()
{
   int i,j,n,temp;
   printf("enter number of elements:");
   scanf("%d",&n);
   int a[n];
   printf("enter the elements:\n");
   for (i=0;i<n;i++)
   {
      scanf("%d",&a[i]);
   }
   for(i=0;i<n-1;i++)
   {
      int flag;
      flag=0;
      for(j=0;j<n-i-1;j++)
      {
         if(a[j]>a[j+1])
         {
            temp=a[j];
            a[j]=a[j+1];
            a[j+1]=temp;
            flag=1;
         }

      }
      if(!flag)
      {
         break;
      }

   }
   printf("sorted array\n");
   for(i=0;i<n;i++)
   {
      printf("%d\n",a[i]);
   }
   return 0;
}
   
